Xmain@0 A0 A1 A2 A3 Clk R0 R1 R2 R3 W0 W1 W2 W3 Wr ESE3700_Project2__main

* ==========================================================================
* Test 1: single-address sanity at addr 1
*   cyc 1 : Wr=1, addr=0001, data=1111 -> write 1111 to addr 1
*   cyc 2 : Wr=0, addr=0001          -> read  (expect 1111)
*   cyc 3 : Wr=1, addr=0001, data=0000 -> write 0000 to addr 1
*   cyc 4 : Wr=0, addr=0001          -> read  (expect 0000)
* ==========================================================================

.param vdd_v = 0.8
.param tr    = 14p
.param tper  = 0.298n

Vdd vdd gnd {vdd_v}
Vclk Clk gnd PULSE({vdd_v} 0 'tper/2 - tr/2' {tr} {tr} 'tper/2 - tr' {tper})

Va0 A0 gnd PWL(
+ 0.0000n  0
+ 0.2910n  0
+ 0.3050n  0.8
+ 0.5890n  0.8
+ 0.6030n  0
+ 0.8870n  0
+ 0.9010n  0.8
