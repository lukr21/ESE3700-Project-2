+ 1.7950n  0
+ 2.0790n  0
+ 2.0930n  0.8
+ 2.3770n  0.8
+ 2.3910n  0
+ 2.6750n  0
+ 2.6890n  0.8
+ 2.9730n  0.8
+ 2.9870n  0
+ 3.2710n  0
+ 3.2850n  0.8
+ 3.5690n  0.8
+ 3.5830n  0
+ 3.8670n  0
+ 3.8810n  0.8
+ 4.1650n  0.8
+ 4.1790n  0
+ 4.4630n  0
+ 4.4770n  0.8
+ 4.7610n  0.8
+ 4.7750n  0
